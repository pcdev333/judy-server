# Local dev overrides for the parseWorkout Edge Function.
# Copy to .env.local (which is gitignored) and fill in your values:
#   cp supabase/functions/parseWorkout/.env.local.example supabase/functions/parseWorkout/.env.local

# Bypass JWT auth for local dev with DEV_BYPASS_AUTH mode in the mobile app.
# NEVER set to true in production.
SKIP_AUTH=true

# Your Google AI API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Your Supabase project credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
