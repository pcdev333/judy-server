# Supabase
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google AI (used in Edge Function only — never expose to client)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ── Local development only ────────────────────────────────────────────────────
# Create a supabase/functions/parseWorkout/.env.local file (gitignored) with
# SKIP_AUTH=true to bypass JWT auth when running locally via:
#   supabase functions serve parseWorkout --env-file supabase/functions/parseWorkout/.env.local
# NEVER set SKIP_AUTH=true in production secrets.
SKIP_AUTH=false
